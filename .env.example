# Пример переменных окружения. Скопируйте в .env и заполните значениями.
# Реальный .env в git не коммитится (см. .gitignore).

# --- Django ---
DEBUG=False
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# Включить редирект на HTTPS за TLS-прокси (в проде — True).
SECURE_SSL_REDIRECT=False
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_DB=foodgram
POSTGRES_USER=foodgram_user
POSTGRES_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# --- Вход через Google (Google Identity Services) ---
# OAuth 2.0 Web Client ID из Google Cloud Console.
# Один и тот же ID используется бэкендом (верификация ID-token) и
# фронтендом (сборка CRA получает его как build-arg REACT_APP_GOOGLE_CLIENT_ID
# через docker-compose). Оставьте пустым, чтобы отключить вход через Google —
# эндпоинт вернёт 503, а кнопка на фронте не отрисуется.
GOOGLE_OAUTH_CLIENT_ID=
